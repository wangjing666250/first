{
  "name": "@xx-ui/pillar-ui",
  "version": "0.0.2",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./button": {
      "types": "./dist/button.d.ts",
      "import": "./dist/button.js"
    },
    "./input": {
      "types": "./dist/input.d.ts",
      "import": "./dist/input.js"
    },
    "./autocomplete": {
      "types": "./dist/autocomplete.d.ts",
      "import": "./dist/autocomplete.js"
    },
    "./upload": {
      "types": "./dist/upload.d.ts",
      "import": "./dist/upload.js"
    },
    "./message": {
      "types": "./dist/message.d.ts",
      "import": "./dist/message.js"
    },
    "./style.css": "./dist/pillar-ui.css"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@xx-ui/theme": "workspace:*"
  },
  "scripts": {
    "test": "vitest -c ../../vitest.config.ts",
    "test:run": "vitest run -c ../../vitest.config.ts",
    "test:coverage": "vitest run -c ../../vitest.config.ts --coverage"
  }
}